# Environment
APP_ENV=development

# Security
SECRET_KEY=replace-with-a-random-secret-key
JWT_SECRET_KEY=replace-with-a-random-jwt-secret-key

# Database / Cache
SQLALCHEMY_DATABASE_URI=mysql+pymysql://user:password@127.0.0.1:3306/flask_boss
REDIS_URI=redis://127.0.0.1:6379/0

# SQLAlchemy
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=5

# Logging / Observability
LOG_LEVEL=DEBUG
LOG_DIR=logs
REQUEST_ID_HEADER=X-Request-ID
SLOW_REQUEST_THRESHOLD_MS=1000

# JWT
JWT_COOKIE_SAMESITE=Lax
JWT_ACCESS_COOKIE_PATH=/
JWT_ACCESS_TOKEN_EXPIRES=15m

# i18n
BABEL_DEFAULT_LOCALE=zh

# Testing-only examples
TEST_SECRET_KEY=test-secret
TEST_JWT_SECRET_KEY=test-jwt-secret
TEST_DATABASE_URI=sqlite+pysqlite:///:memory:
TEST_REDIS_URI=memory://


IMAGE_STORAGE_PROVIDER=imgbb
# Third-party API keys
IMGBB_API_KEY=7ede6d75c109995de4d59f8d9f10d1c6
